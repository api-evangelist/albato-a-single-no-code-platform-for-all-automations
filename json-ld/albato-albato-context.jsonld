      "@id": "albato:event",
      "@type": "xsd:string"
    },
    "config": {
      "@id": "albato:config",
      "@type": "xsd:string"
    },
    "Execution": {
      "@id": "albato:Execution"
    },
    "automation_id": {
      "@id": "albato:automation_id",
